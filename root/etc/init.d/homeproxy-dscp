#!/bin/sh /etc/rc.common
# SPDX-License-Identifier: GPL-2.0-only

START=99
STOP=10
USE_PROCD=1

RUN_DIR="/var/run/homeproxy-dscp"
GENERATOR="/usr/share/homeproxy-dscp/generate.uc"
TABLE_NAME="homeproxy_dscp"

load_state() {
	[ -f "$RUN_DIR/state" ] && . "$RUN_DIR/state"
}

cleanup_policy() {
	load_state

	if [ -n "$FWMARK" ] && [ -n "$TABLE" ]; then
		if [ -n "$RULE_PRIORITY" ]; then
			while ip -4 rule del fwmark "$FWMARK" table "$TABLE" priority "$RULE_PRIORITY" 2>/dev/null; do
				:
			done
		else
			while ip -4 rule del fwmark "$FWMARK" table "$TABLE" 2>/dev/null; do
				:
			done
		fi
	fi

	[ -n "$TABLE" ] && ip -4 route flush table "$TABLE" 2>/dev/null
}

cleanup_nft() {
	nft delete table inet "$TABLE_NAME" 2>/dev/null
}

start_service() {
	[ -x "$GENERATOR" ] || {
		echo "homeproxy-dscp: generator not found: $GENERATOR" >&2
		return 1
	}

	ucode "$GENERATOR" || return 1
	load_state

	[ -n "$CONFIG_FILE" ] && [ -f "$CONFIG_FILE" ] || {
		echo "homeproxy-dscp: generated sing-box config missing" >&2
		return 1
	}
	[ -n "$NFT_FILE" ] && [ -f "$NFT_FILE" ] || {
		echo "homeproxy-dscp: generated nftables ruleset missing" >&2
		return 1
	}

	sing-box check -c "$CONFIG_FILE" || return 1
	cleanup_nft
	nft -c -f "$NFT_FILE" || return 1

	cleanup_policy
	if [ "$HAS_UDP" = "1" ]; then
		ip -4 route replace local default dev lo table "$TABLE" || return 1
		ip -4 rule add fwmark "$FWMARK" table "$TABLE" priority "$RULE_PRIORITY" || return 1
	fi

	nft -f "$NFT_FILE" || return 1

	procd_open_instance
	procd_set_param command /usr/bin/sing-box run -c "$CONFIG_FILE"
	procd_set_param respawn 3600 5 5
	procd_set_param file /etc/config/homeproxy_dscp /etc/config/homeproxy "$CONFIG_FILE"
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

stop_service() {
	cleanup_nft
	cleanup_policy
}

reload_service() {
	stop
	start
}

service_triggers() {
	procd_add_reload_trigger homeproxy_dscp homeproxy
}
